<!-- ============================================
     Halaman Dashboard — FTI HC
     
     Halaman pertama yang terlihat setelah login
     Menampilkan informasi ringkasan akun user
     
     Styling menggunakan Basecoat UI (card, badge) + Tailwind CSS
     ============================================ -->
<div class="space-y-8">
    <!-- Bagian welcome -->
    <div>
        <h1 class="text-xl font-semibold text-gray-900">Selamat Datang, <%= user.name %>!</h1>
        <p class="text-sm text-gray-400 mt-1">Berikut adalah ringkasan informasi akun kamu.</p>
    </div>

    <!-- Grid card statistik — Basecoat card component -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <!-- Card 1: Email (Basecoat card) -->
        <div class="card">
            <section class="space-y-3">
                <div class="flex items-center justify-between">
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Email</p>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gray-300"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <p class="text-lg font-semibold text-gray-900 truncate"><%= user.email %></p>
            </section>
        </div>

        <!-- Card 2: Role (Basecoat card) -->
        <div class="card">
            <section class="space-y-3">
                <div class="flex items-center justify-between">
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Role</p>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gray-300"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <p class="text-lg font-semibold text-gray-900"><%= user.role_name %></p>
            </section>
        </div>

        <!-- Card 3: Status (Basecoat card) -->
        <div class="card">
            <section class="space-y-3">
                <div class="flex items-center justify-between">
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Status</p>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-green-500"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div class="flex items-center gap-2">
                    <span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>
                    <p class="text-lg font-semibold text-green-600">Aktif</p>
                </div>
            </section>
        </div>
    </div>
</div>
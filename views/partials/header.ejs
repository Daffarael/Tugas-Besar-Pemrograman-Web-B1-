<!-- ============================================
     Header — FTI HC
     
     Bar di bagian atas halaman
     Berisi: judul halaman (kiri) + info user + tombol logout (kanan)
     
     Styling menggunakan Tailwind CSS + Basecoat UI (btn)
     ============================================ -->
<header class="app-header">
    <div class="flex items-center justify-between w-full px-6 h-14">

        <!-- Judul halaman -->
        <h2 class="text-sm font-semibold text-gray-700 tracking-wide">
            <%= typeof title !== 'undefined' ? title : 'FTI HC' %>
        </h2>

        <!-- Info user + tombol logout -->
        <% if (user) { %>
            <div class="flex items-center gap-3">
                <!-- Avatar kecil (inisial nama) -->
                <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-semibold text-gray-500">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <!-- Nama dan role -->
                <div class="text-right hidden sm:block">
                    <div class="text-sm font-medium text-gray-700 leading-tight"><%= user.name %></div>
                    <div class="text-[11px] text-gray-400"><%= user.role_name %></div>
                </div>
                <!-- Tombol logout (Basecoat btn-ghost) -->
                <form action="/auth/logout" method="POST" class="m-0">
                    <button type="submit" class="btn-sm-ghost text-gray-400 hover:text-gray-600">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </button>
                </form>
            </div>
        <% } %>
    </div>
</header>